  "keyFeatures": [
    "Tag-based parameter resolution (body, header, query, path, cookie, form, file)",
    "Automatic type conversion for primitives (string, int, bool, float, pointers)",
    "Zero-reflection runtime overhead (analysis happens once at startup)",
    "Standard http.HandlerFunc output compatible with any Go router",
    "Plain function handlers without framework-specific context parameters",
    "Automatic error handling and JSON response encoding"
  ],
  "publicApiSurface": [
    "handler.Adapt(fn) - Main adapter function",
    "handler.Context - Request context wrapper",
    "Resolver tags: json:\"body\", json:\"header:<name>\", json:\"query:<name>\", json:\"path:<name>\", json:\"cookie:<name>\", json:\"form:<name>\", json:\"file:<name>\""
  ]
